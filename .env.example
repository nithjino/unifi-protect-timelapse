# Copy this file to .env and replace these values with your UniFi Protect details.
UNIFI_PROTECT_URL=
UNIFI_PROTECT_TOKEN=
# Use a dedicated local Protect user with permission to view/export recordings.
# Do not use an owner account or a UI.com SSO account.
UNIFI_PROTECT_USERNAME=
UNIFI_PROTECT_PASSWORD=
UNIFI_PROTECT_VERIFY_SSL=true

# Optional runtime defaults. Speed and dates must be passed on the command line.
# TIMELAPSE_OUTPUT=timelapse.mp4
# Maximum time in seconds for the export request and download to complete.
# Set to 0 to disable the timeout for exports that may take a long time.
TIMELAPSE_REQUEST_TIMEOUT_SECONDS=0
# Maximum allowed download size in MiB, protecting local disk space from
# unexpectedly large exports. The default is 10240 MiB (10 GiB); 0 disables the limit.
TIMELAPSE_MAX_DOWNLOAD_MIB=10240

# Web UI settings. The local start script listens only on this computer by
# default. Set the host to 0.0.0.0 to allow other devices on the local network.
# Web ranges, previews, display, and daily schedules default to UTC. Uncomment
# and set an IANA timezone name to use another timezone.
# TZ=America/New_York
TIMELAPSE_WEB_HOST=127.0.0.1
# Comma-separated server hostnames or IP addresses browsers may use to reach
# the UI. These values match the address in the browser URL (the HTTP Host
# header), not the IP addresses of client devices connecting to the server.
# For example, http://thinkpad:8000 requires "thinkpad" here, while
# http://192.168.2.17:8000 requires "192.168.2.17". Do not include the port.
# Required for LAN/reverse-proxy access when TIMELAPSE_WEB_HOST is a wildcard.
# After changing this value for Docker, recreate the container with:
# docker compose up -d --force-recreate timelapse-web
TIMELAPSE_WEB_TRUSTED_HOSTS=localhost,127.0.0.1
TIMELAPSE_WEB_PORT=8000
TIMELAPSE_WEB_DATA_DIR=./data
# TIMELAPSE_WEB_OUTPUT_DIR=./data/exports
TIMELAPSE_WEB_USERNAME=timelapse
# Required by docker-compose.yaml and whenever TIMELAPSE_WEB_HOST is not local.
TIMELAPSE_WEB_PASSWORD=
# Login sessions expire after this many hours. Set secure cookies to true when
# the web UI is served through an HTTPS reverse proxy.
TIMELAPSE_WEB_SESSION_HOURS=168
TIMELAPSE_WEB_COOKIE_SECURE=false
# Bound concurrent/queued work, requested duration, and aggregate export storage.
TIMELAPSE_WEB_MAX_ACTIVE_EXPORTS=4
TIMELAPSE_WEB_MAX_QUEUED_EXPORTS=20
TIMELAPSE_WEB_MAX_EXPORT_HOURS=168
TIMELAPSE_WEB_STORAGE_QUOTA_MIB=102400
# Docker port publishing address. Use 127.0.0.1 to keep Docker host-only.
TIMELAPSE_WEB_BIND_ADDRESS=0.0.0.0
