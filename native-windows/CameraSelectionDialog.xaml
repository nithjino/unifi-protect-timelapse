<Window x:Class="TimeLapseNative.CameraSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Cameras" Width="540" Height="450" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
  <Grid Margin="20">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
    <TextBlock Text="Select Cameras" FontSize="21" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="Choose one or more cameras. Each camera downloads in its own background process."
               Foreground="#666" TextWrapping="Wrap" Margin="0,5,0,12" />
    <ListBox x:Name="CameraList" Grid.Row="2">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <CheckBox IsChecked="{Binding Selected}" Margin="7,5">
            <StackPanel>
              <TextBlock Text="{Binding Camera.Name}" />
              <TextBlock Text="{Binding Details}" Foreground="#777" FontSize="11" />
            </StackPanel>
          </CheckBox>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <DockPanel Grid.Row="3" Margin="0,12,0,0">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Content="Cancel" IsCancel="True" Margin="0,0,8,0" />
        <Button Content="OK" IsDefault="True" Click="Ok_Click" Background="#1769C2" Foreground="White" />
      </StackPanel>
      <Button Content="Select All" Click="SelectAll_Click" Margin="0,0,8,0" />
      <Button Content="Clear" Click="Clear_Click" />
    </DockPanel>
  </Grid>
</Window>
