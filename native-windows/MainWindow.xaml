<Window x:Class="TimeLapseNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UniFi Protect Timelapse" Width="1400" Height="680"
        MinWidth="1250" MinHeight="560" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
      <StackPanel>
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
            <Button Content="＋ New" Click="NewProfile_Click" Margin="0,0,8,0" />
            <Button x:Name="EditProfileButton" Content="✎ Edit" Click="EditProfile_Click" />
          </StackPanel>
          <TextBlock Text="⌁  Connection" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,14,0" />
          <ComboBox x:Name="ProfileCombo" Width="280" DisplayMemberPath="DisplayName"
                    SelectionChanged="ProfileCombo_SelectionChanged" />
        </DockPanel>
        <TextBlock x:Name="ConnectionUrlText" Foreground="#666" Margin="0,9,0,0" TextTrimming="CharacterEllipsis" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="◷  New Timelapse" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,11" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid Grid.Column="0" Margin="0,0,18,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="55" />
              <ColumnDefinition Width="190" />
              <ColumnDefinition Width="85" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Start" Foreground="#666" VerticalAlignment="Center" />
            <Border x:Name="StartDateTimeHoverTarget" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="Transparent"
                    Margin="0,0,0,8" Tag="start" MouseEnter="ThumbnailHover_MouseEnter" MouseLeave="ThumbnailHover_MouseLeave">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="85" />
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="StartDatePicker" Margin="0,0,8,0" SelectedDateChanged="StartDate_SelectedDateChanged" />
                <TextBox x:Name="StartTimeText" Grid.Column="1" Text="12:00 AM" VerticalContentAlignment="Center"
                         TextChanged="TimeText_TextChanged" />
              </Grid>
            </Border>
            <TextBlock Grid.Row="1" Text="End" Foreground="#666" VerticalAlignment="Center" />
            <Border x:Name="EndDateTimeHoverTarget" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Background="Transparent"
                    Margin="0,0,0,8" Tag="end" MouseEnter="ThumbnailHover_MouseEnter" MouseLeave="ThumbnailHover_MouseLeave">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="85" />
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="EndDatePicker" Margin="0,0,8,0" SelectedDateChanged="EndDate_SelectedDateChanged" />
                <TextBox x:Name="EndTimeText" Grid.Column="1" Text="12:00 AM" VerticalContentAlignment="Center"
                         TextChanged="TimeText_TextChanged" />
              </Grid>
            </Border>
            <TextBlock Grid.Row="2" Text="Speed" Foreground="#666" VerticalAlignment="Center" />
            <ComboBox x:Name="SpeedCombo" Grid.Row="2" Grid.Column="1" Width="105" HorizontalAlignment="Left" SelectedIndex="3">
              <ComboBoxItem Content="60x" />
              <ComboBoxItem Content="120x" />
              <ComboBoxItem Content="300x" />
              <ComboBoxItem Content="600x" />
            </ComboBox>
            <CheckBox x:Name="FullDayCheckBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Content="24-hour timelapse"
                      Margin="0,8,0,0" Checked="FullDay_Checked" Unchecked="FullDay_Unchecked" />
          </Grid>
          <Border Grid.Column="1" Background="#D8D8DC" />
          <Grid Grid.Column="2" Margin="18,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="86" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="▰  Save to" Foreground="#666" VerticalAlignment="Center" />
            <TextBlock x:Name="OutputDirectoryText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,8" />
            <Button Grid.Row="0" Grid.Column="2" Content="Choose…" Click="ChooseOutput_Click" Margin="0,0,0,8" />
            <TextBlock Grid.Row="1" Text="▣  Cameras" Foreground="#666" VerticalAlignment="Center" />
            <TextBlock x:Name="CameraSummaryText" Grid.Row="1" Grid.Column="1" Text="No cameras selected" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,8,8" />
            <Button x:Name="SelectCamerasButton" Grid.Row="1" Grid.Column="2" Content="Select…" Click="SelectCameras_Click" Margin="0,0,8,8" />
            <Button x:Name="RefreshCamerasButton" Grid.Row="1" Grid.Column="3" Content="↻" ToolTip="Refresh cameras" Click="RefreshCameras_Click" Margin="0,0,0,8" />
            <Button x:Name="StartDownloadsButton" Grid.Row="2" Grid.ColumnSpan="2" Content="↓  Start Downloads" Click="StartDownloads_Click"
                    HorizontalAlignment="Left" Background="#1769C2" Foreground="White" FontWeight="SemiBold" IsEnabled="False" />
            <CheckBox x:Name="DailyAutomaticCheckBox" Grid.Row="3" Grid.ColumnSpan="3" Content="Daily automatic timelapses"
                      Margin="0,9,0,0" Checked="DailyAutomatic_Checked" Unchecked="DailyAutomatic_Unchecked" />
          </Grid>
        </Grid>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,9">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="⇩  Jobs" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button x:Name="ClearAllButton" Content="Clear All" Click="ClearAll_Click" Margin="0,0,8,0" IsEnabled="False" />
            <Button x:Name="CancelAllButton" Content="Cancel All" Click="CancelAll_Click" IsEnabled="False" />
          </StackPanel>
        </DockPanel>
        <TabControl x:Name="JobsTabControl" Grid.Row="1">
          <TabItem Header="Downloads">
            <Grid Margin="0,8,0,0">
              <StackPanel x:Name="EmptyDownloadsPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="No downloads yet" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Select cameras and start a timelapse to track it here." Foreground="#777" Margin="0,3,0,0" />
              </StackPanel>
              <DataGrid x:Name="DownloadsGrid" ItemsSource="{Binding DownloadJobs}" AutoGenerateColumns="False" CanUserAddRows="False"
                        IsReadOnly="True" Visibility="Collapsed" MouseDoubleClick="JobsGrid_MouseDoubleClick">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Job" Binding="{Binding GroupNumber}" Width="48" />
                  <DataGridTextColumn Header="Camera" Binding="{Binding CameraName}" Width="130" />
                  <DataGridTextColumn Header="Time Range" Binding="{Binding TimeRangeText}" Width="220" />
                  <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="150" />
                  <DataGridTemplateColumn Header="Progress" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate><ProgressBar Value="{Binding Progress}" Height="12" Margin="4" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedText}" Width="95" />
                  <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedText}" Width="90" />
                  <DataGridTextColumn Header="Speed" Binding="{Binding SpeedText}" Width="90" />
                  <DataGridTextColumn Header="Output" Binding="{Binding OutputName}" Width="*" />
                  <DataGridTemplateColumn Header="Action" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate><Button Content="{Binding ActionText}" Click="JobAction_Click" Padding="8,2" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </TabItem>
          <TabItem Header="Daily Automations">
            <Grid Margin="0,8,0,0">
              <StackPanel x:Name="EmptyDailyAutomationsPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="No daily automations" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Enable daily automatic timelapses to track the schedule here." Foreground="#777" Margin="0,3,0,0" />
              </StackPanel>
              <DataGrid x:Name="DailyAutomationsGrid" ItemsSource="{Binding DailyAutomationJobs}" AutoGenerateColumns="False" CanUserAddRows="False"
                        IsReadOnly="True" Visibility="Collapsed" MouseDoubleClick="JobsGrid_MouseDoubleClick">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Job" Binding="{Binding GroupNumber}" Width="48" />
                  <DataGridTextColumn Header="Camera" Binding="{Binding CameraName}" Width="130" />
                  <DataGridTextColumn Header="Time Range" Binding="{Binding TimeRangeText}" Width="220" />
                  <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="150" />
                  <DataGridTemplateColumn Header="Progress" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate><ProgressBar Value="{Binding Progress}" Height="12" Margin="4" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Header="Downloaded" Binding="{Binding DownloadedText}" Width="95" />
                  <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedText}" Width="90" />
                  <DataGridTextColumn Header="Speed" Binding="{Binding SpeedText}" Width="90" />
                  <DataGridTextColumn Header="Output" Binding="{Binding OutputName}" Width="*" />
                  <DataGridTemplateColumn Header="Action" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate><Button Content="{Binding ActionText}" Click="JobAction_Click" Padding="8,2" /></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </TabItem>
        </TabControl>
      </Grid>
    </Border>

    <DockPanel Grid.Row="3">
      <Button DockPanel.Dock="Right" Content="☰  Logs" Click="Logs_Click" />
      <StackPanel x:Name="WorkingPanel" DockPanel.Dock="Right" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,14,0">
        <ProgressBar Width="60" Height="6" IsIndeterminate="True" Margin="0,0,8,0" />
        <TextBlock Text="Working" Foreground="#666" VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock x:Name="StatusText" Text="Ready" Foreground="#666" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
    </DockPanel>

    <Popup x:Name="ThumbnailPopup" Placement="Right" HorizontalOffset="8" AllowsTransparency="True"
           PopupAnimation="Fade" StaysOpen="True" IsHitTestVisible="False">
      <Border Background="White" BorderBrush="#B8B8BC" BorderThickness="1" CornerRadius="9" Padding="11">
        <StackPanel Width="320">
          <TextBlock x:Name="ThumbnailTitle" FontWeight="SemiBold" FontSize="14" />
          <TextBlock x:Name="ThumbnailTime" Foreground="#666" Margin="0,3,0,8" />
          <Grid Width="320" Height="180" Background="Black">
            <Image x:Name="ThumbnailImage" Stretch="Uniform" />
            <TextBlock x:Name="ThumbnailMessage" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"
                       VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="260" />
          </Grid>
          <TextBlock x:Name="ThumbnailCamera" Foreground="#666" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
          <TextBlock x:Name="ThumbnailSource" Foreground="#B56800" FontWeight="SemiBold" Margin="0,4,0,0"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </Popup>
  </Grid>
</Window>
