<Window x:Class="TimeLapseNative.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Application Logs" Width="760" Height="420" MinWidth="560" MinHeight="280" WindowStartupLocation="CenterOwner">
  <Grid Margin="12">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
    <DockPanel Margin="0,0,0,8">
      <Button DockPanel.Dock="Right" Content="Clear" Click="Clear_Click" />
      <TextBlock Text="Application Logs" FontWeight="SemiBold" VerticalAlignment="Center" />
    </DockPanel>
    <ListBox x:Name="LogList" Grid.Row="1" FontFamily="Consolas" FontSize="12" ItemsSource="{Binding Logs}" />
  </Grid>
</Window>
